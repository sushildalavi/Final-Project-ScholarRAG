# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
RESEARCH_CHAT_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBED_TIMEOUT=120

# ── Embeddings ─────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=mxbai-embed-large
EMBEDDING_QUERY_PREFIX=Represent this sentence for searching relevant passages:
EMBEDDING_DOC_PREFIX=Represent this document for retrieval:
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TIMEOUT_SECONDS=45
EMBEDDING_RETRY_ATTEMPTS=3
EMBEDDING_RETRY_DELAY=0.75
EMBEDDING_VERSION=mxbai-embed-large-v1
EMBEDDING_RAW_DIM=1024
VECTOR_STORE_DIM=1536
EMBEDDING_MAX_QUERY_WORDS=128
EMBEDDING_MAX_DOC_WORDS=256

# ── Scholarly API providers (all optional) ─────────────────────────────────
OPENALEX_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
SPRINGER_API_KEY=
SPRINGER_META_VERSION=v2
ELSEVIER_API_KEY=
IEEE_API_KEY=
ARXIV_API_URL=https://export.arxiv.org/api/query

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://scholarrag:scholarrag@127.0.0.1:5432/scholarrag_db

# ── Retrieval defaults ─────────────────────────────────────────────────────
TOP_K_VECTOR=12
TOP_K_LEXICAL=12
TOP_K_FINAL=8
MAX_CHUNK_TOKENS=700
CHUNK_OVERLAP=120

# ── CORS (comma-separated origins, optional) ──────────────────────────────
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Google OAuth (optional, for /auth/google endpoint) ────────────────────
# GOOGLE_CLIENT_ID=

# ── Web fallback (optional DuckDuckGo/Wikipedia when public search empty) ─
# ENABLE_WEB_FALLBACK=false

# ── Frontend ───────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://127.0.0.1:8000
